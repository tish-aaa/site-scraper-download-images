# Ignore all downloaded image formats (scraped product images)
*.webp
*.jpg
*.jpeg
*.avif

# Ignore PNGs everywhere EXCEPT the screenshots folder
*.png
!/screenshots/*.png

# Ignore the activity log file
activity.log

# Ignore all folders by default (scraper output folders)...
**/
# ...except these
!/.gitignore
!/scraper.py
!/bot.php
!/README.md
!/requirements.txt
!/screenshots/

# Python environment & cache
__pycache__/
*.py[cod]
*$py.class
venv/
.env